{
    "name": "dlunire/dlparse",
    "description": "DLParse: Biblioteca PHP ligera para normalización segura de bytes, parsing de entornos tipados, inputs HTTP y DSLs personalizados. Soporte completo Unicode, manejo preciso de BOM y whitespace invisible. Parte del ecosistema DLUnire Framework.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "David E Luna M",
            "email": "dlunireframework@gmail.com",
            "homepage": "https://github.com/dlunire",
            "role": "Developer"
        }
    ],
    "keywords": [
        "parser",
        "lexer",
        "normalizer",
        "unicode",
        "bom",
        "environment",
        "typed env",
        "http input",
        "dlunire"
    ],
    "homepage": "https://github.com/dlunire/dlparse",
    "support": {
        "issues": "https://github.com/dlunire/dlparse/issues",
        "source": "https://github.com/dlunire/dlparse"
    },
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "DLParse\\": "src/"
        }
    },
    "bin": [
        "bin/normalizer.php"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}